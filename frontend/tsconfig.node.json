{
  "compilerOptions": {
    "composite": true,
    "skipLibCheck": true,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "noEmit": false,
    "outDir": "electron-dist",
    "target": "ES2020"
  },
  "include": ["vite.config.ts", "electron/main.ts", "electron/updater.ts", "electron/updater-loader.d.cts"]
}
