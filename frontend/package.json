{
  "name": "aln-data-frontend",
  "private": true,
  "version": "0.2.0",
  "description": "ALN Resonator Test Data Platform",
  "author": "aln-data <dev@aln-data.local>",
  "type": "module",
  "main": "electron-dist/electron/main.js",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "vite build && npm run electron:build-main",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "electron:build-main": "tsc -p tsconfig.node.json --outDir electron-dist && node scripts/copy-electron-assets.js",
    "electron:dev": "npm run electron:build-main && concurrently \"npm run dev\" \"wait-on http://127.0.0.1:5173 && electron .\"",
    "electron:preview": "npm run build && electron .",
    "electron:pack": "npm run build && electron-builder",
    "dist": "npm run build && electron-builder"
  },
  "homepage": ".",
  "build": {
    "appId": "com.alndata.desktop",
    "productName": "ALN Resonator Data Platform",
    "copyright": "Copyright © 2026 aln-data",
    "directories": {
      "output": "release",
      "buildResources": "build-resources"
    },
    "files": [
      "dist/**/*",
      "electron-dist/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "build/backend",
        "to": "backend",
        "filter": [
          "**/*"
        ]
      }
    ],
    "protocols": [
      {
        "name": "ALN Data Platform",
        "schemes": [
          "alndata"
        ]
      }
    ],
    "publish": [
      {
        "provider": "github",
        "owner": "your-org",
        "repo": "aln-data"
      }
    ],
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "icon": "build-resources/icon.icns",
      "category": "public.app-category.science",
      "hardenedRuntime": false,
      "gatekeeperAssess": false
    },
    "dmg": {
      "sign": false,
      "contents": [
        {
          "x": 130,
          "y": 220
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ]
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build-resources/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "ALN Data Platform"
    }
  },
  "dependencies": {
    "axios": "^1.7.9",
    "electron-updater": "^6.8.9",
    "plotly.js-dist-min": "^2.35.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-plotly.js": "^2.6.0",
    "react-router-dom": "^6.28.1"
  },
  "devDependencies": {
    "@types/node": "^20.19.43",
    "@types/react": "^18.3.31",
    "@types/react-dom": "^18.3.7",
    "@types/react-plotly.js": "^2.6.4",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^10.0.3",
    "electron": "^42.4.0",
    "electron-builder": "^26.15.3",
    "typescript": "^5.4.5",
    "vite": "^5.4.11",
    "wait-on": "^9.0.10"
  }
}
