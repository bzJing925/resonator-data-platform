# 谐振器数据平台 - 环境变量模板
# 复制为 .env 并填入实际值。.env 不进 git。
#   Linux/macOS：  cp .env.example .env
#   Windows PS：   Copy-Item .env.example .env

# ===== 数据库 =====
POSTGRES_DB=aln
POSTGRES_USER=aln
# 部署到生产/共享机器时务必改掉。建议 16 位以上，避免特殊字符（&、$、引号）以免 .env 解析坑
POSTGRES_PASSWORD=changeme_in_prod

# ===== 应用 =====
# 数据根目录：pgdata / redis / uploads / files / exports / logs 全部落在这里。
# 强烈建议写【绝对路径】，避免 docker compose 把相对路径解析到 deploy/ 子目录下。
# bootstrap.sh / bootstrap.ps1 会兜底把 ./xxx 自动展开为绝对路径，但直接 docker compose up 不会。
#
# 三种典型写法（任选其一）：
#   1) Linux 数据盘绝对路径（生产推荐）：
DATA_ROOT=/data3/aln
#   2) 项目内 ./data（开发；用脚本启动时安全，手动 docker compose 时务必先改成绝对）：
# DATA_ROOT=./data
#   3) Windows 自定义盘（用正斜杠 / 或双反斜杠 \\，单个 \ 会被 shell 吃掉）：
# DATA_ROOT=D:/aln-data
#
# 切换 DATA_ROOT 后，旧路径下的数据库不会自动迁移，需要重新初始化或手动拷贝。
UPLOAD_MAX_GB=20
LOG_LEVEL=INFO

# ===== 任务队列 =====
WORKER_CONCURRENCY=4
# 参数提取并行 worker 数（仅 Linux 生产环境有效，macOS 开发环境建议保持 1）
# WORKER_EXTRACT_WORKERS=4

# ===== 数据库连接池 =====
# 根据并发量调整；4 uvicorn worker + 4 celery worker 推荐 20/30
# DB_POOL_SIZE=20
# DB_MAX_OVERFLOW=30
# DB_POOL_RECYCLE=3600

# ===== 反向代理 =====
# 浏览器访问 http://localhost:<NGINX_PORT>
NGINX_PORT=8080
